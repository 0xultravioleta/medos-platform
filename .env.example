# ============================================================
# MedOS Platform - Environment Variables
# Copy to .env and fill in values. NEVER commit .env
# ============================================================

# --- Application ---
APP_NAME=medos-platform
APP_ENV=development  # development | staging | production
APP_DEBUG=true
APP_VERSION=0.1.0
APP_PORT=8000
APP_HOST=0.0.0.0

# --- Database (PostgreSQL 17 + pgvector) ---
DATABASE_URL=postgresql+asyncpg://medos:YOUR_DB_PASSWORD@localhost:5432/medos_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth (SMART on FHIR / OAuth2) ---
AUTH_PROVIDER=auth0  # auth0 | clerk | keycloak
AUTH_DOMAIN=YOUR_AUTH_DOMAIN
AUTH_CLIENT_ID=YOUR_CLIENT_ID
AUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET
AUTH_AUDIENCE=https://api.medos.health
JWKS_URL=https://YOUR_AUTH_DOMAIN/.well-known/jwks.json

# --- AI / LLM ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# --- Speech-to-Text ---
WHISPER_ENDPOINT=http://localhost:8001/transcribe
WHISPER_MODEL=large-v3

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=YOUR_ACCOUNT_ID
S3_BUCKET_ATTACHMENTS=medos-attachments-dev
S3_BUCKET_AUDIT=medos-audit-dev

# --- Observability ---
LANGFUSE_PUBLIC_KEY=YOUR_LANGFUSE_PUBLIC_KEY
LANGFUSE_SECRET_KEY=YOUR_LANGFUSE_SECRET_KEY
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=YOUR_SENTRY_DSN

# --- FHIR ---
FHIR_BASE_URL=http://localhost:8000/fhir/r4
FHIR_VERSION=4.0.1

# --- Clearinghouse (for RCM) ---
CLEARINGHOUSE_PROVIDER=availity  # availity | change_healthcare
CLEARINGHOUSE_API_URL=YOUR_CLEARINGHOUSE_URL
CLEARINGHOUSE_API_KEY=YOUR_CLEARINGHOUSE_KEY

# --- Feature Flags ---
ENABLE_AI_CODING=true
ENABLE_PRIOR_AUTH=false
ENABLE_WHISPER=false
